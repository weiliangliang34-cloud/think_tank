# embedding模型！ 进行向量生成！！ 魔搭下载模型到本地！！
BGE_M3_PATH=D:\ai_models\modelscope_cache\models\BAAI\bge-m3
BGE_M3=BAAI/bge-m3
# gpu
# BGE_DEVICE=cuda:0
# cpu 
 BGE_DEVICE=cpu
# cpu 需要关闭 0  GPU 上生成向量通常默认开启了半精度浮点数（FP16）加速，而 CPU 上通常使用单精度（FP32）
BGE_FP16=0
ITEM_NAME_DIAG=1

